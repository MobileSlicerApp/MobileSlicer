+size_t ViewerImpl::load_layer_range(const GCodeInputData& gcode_data, long min_layer, long max_layer, size_t max_vertices)
+{
+    if (!m_initialized || gcode_data.vertices.empty())
+        return 0;
+
+    const bool layer_filter_enabled = min_layer >= 0 && max_layer >= min_layer;
+    const bool limit_enabled = max_vertices > 0;
+    size_t selected_vertices = 0;
+    for (const PathVertex& source_vertex : gcode_data.vertices) {
+        const long layer_id = static_cast<long>(source_vertex.layer_id);
+        if (!layer_filter_enabled || (layer_id >= min_layer && layer_id <= max_layer)) {
+            ++selected_vertices;
+            if (limit_enabled && selected_vertices >= max_vertices)
+                return selected_vertices;
+        }
+    }
+
+    if (selected_vertices == 0)
+        return 0;
+
+    std::vector<PathVertex> vertices;
+    vertices.reserve(selected_vertices);
+    for (const PathVertex& source_vertex : gcode_data.vertices) {
+        const long layer_id = static_cast<long>(source_vertex.layer_id);
+        if (layer_filter_enabled && (layer_id < min_layer || layer_id > max_layer))
+            continue;
+
+        PathVertex vertex = source_vertex;
+        if (layer_filter_enabled)
+            vertex.layer_id = static_cast<uint32_t>(layer_id - min_layer);
+        vertices.emplace_back(vertex);
+    }
+
+    load_vertices(std::move(vertices), Palette(gcode_data.tools_colors), Palette(gcode_data.color_print_colors), gcode_data.spiral_vase_mode);
+    return selected_vertices;
+}
